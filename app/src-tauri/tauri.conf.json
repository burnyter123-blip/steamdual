{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SteamDualBoot",
  "version": "0.1.0",
  "identifier": "com.steamdualboot.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SteamDualBoot",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": ["icons/icon.png"],
    "category": "Utility",
    "shortDescription": "Windows 11 dual-boot for the Steam Deck"
  }
}
